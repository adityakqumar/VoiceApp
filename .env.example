# VoiceApp Environment Variables

# Server
PORT=5000
CLIENT_URL=http://localhost:3000
JWT_SECRET=change-this-to-a-secure-random-string
MONGODB_URI=mongodb://localhost:27017/voiceapp

# Client (prefix with NEXT_PUBLIC_ for browser access)
NEXT_PUBLIC_API_URL=http://localhost:5000

# TURN Server (optional, for production NAT traversal)
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=your-username
# TURN_CREDENTIAL=your-credential

# Email Service (optional, for production OTP delivery)
# EMAIL_SERVICE=sendgrid
# EMAIL_API_KEY=your-api-key
# EMAIL_FROM=noreply@voiceapp.com
