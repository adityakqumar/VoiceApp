# ============================
# VoiceApp — Production Environment Variables
# ============================
# Copy this to your Railway (or hosting) dashboard as environment variables.

# === SERVER (set these on the SERVER service) ===
PORT=5000
CLIENT_URL=https://your-client-domain.up.railway.app
JWT_SECRET=GENERATE_A_STRONG_RANDOM_SECRET_HERE
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/voiceapp?retryWrites=true&w=majority

# Gmail SMTP (for sending OTP emails)
EMAIL_SERVICE=gmail
EMAIL_USER=adityakqumar@gmail.com
EMAIL_PASS=your-gmail-app-password

# === CLIENT (set these on the CLIENT service) ===
NEXT_PUBLIC_API_URL=https://your-server-domain.up.railway.app

# TURN Server — Metered.ca (sign up free at https://dashboard.metered.ca/signup)
# After signup, go to Dashboard > TURN Server > Get API Key
NEXT_PUBLIC_METERED_API_KEY=your-metered-api-key
# NEXT_PUBLIC_METERED_DOMAIN=global.relay.metered.ca  # optional, default works
